{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typola",
  "version": "2.0.5-dev",
  "identifier": "com.typola.reader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Typola",
        "width": 980,
        "height": 680,
        "resizable": true,
        "visible": true,
        "maximized": true,
        "fullscreen": false,
        "theme": "Light",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 16
        },
        "backgroundColor": "#f8f2e9"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost https: http:; font-src 'self' file:; connect-src 'self'; media-src 'self' file:; frame-src 'self' data: blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$HOME/.typola-output/**",
          "$HOME/**/.typola-output/**",
          "$PICTURE/**",
          "$VIDEO/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ttttstc/Typola/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1QzVGMTFGQjRCMzc0NUMKUldSY2RMTzBIL0hGMVJ2b1IrS1FZSTRmVDlpS3QvcGVmYWNLK2x1LytEOE9KZ3RNeGxnamZ6WnEK"
    }
  },
    "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": false,
    "resources": [
      "resources/MicrosoftEdgeWebview2Setup.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": ["html", "htm"],
        "name": "HTML Document",
        "description": "HTML document",
        "mimeType": "text/html",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": ["docx"],
        "name": "Word Document",
        "description": "Word document",
        "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "template": "./windows/main.wxs"
      },
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
