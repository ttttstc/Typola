{
  "name": "typola",
  "private": true,
  "version": "0.3.21",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "npm run typecheck && vite build --config config/vite.config.ts",
    "lint": "eslint . --config config/eslint.config.js",
    "typecheck": "tsc -b config/tsconfig.json",
    "test": "vitest run --config config/vite.config.ts",
    "test:e2e": "playwright test --config config/playwright.config.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "tauri": "tauri",
    "tauri:build:local": "tauri build --config \"{\\\"bundle\\\":{\\\"createUpdaterArtifacts\\\":false}}\"",
    "portable:package": "node scripts/build-portable.mjs",
    "tauri:build:portable": "npm run tauri:build:local && npm run portable:package",
    "tauri:build:update": "tauri build --config \"{\\\"bundle\\\":{\\\"createUpdaterArtifacts\\\":true}}\"",
    "updater:manifest": "node scripts/create-updater-manifest.mjs",
    "perf:bundle": "node scripts/perf/capture-bundle-size.mjs",
    "perf:bundle:check": "node scripts/perf/assert-bundle-budget.mjs",
    "perf:bundle:report": "node scripts/perf/collect-bundle-size.mjs"
  },
  "dependencies": {
    "@atomic-editor/editor": "0.4.3",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.0",
    "@floating-ui/react": "^0.27.19",
    "@formkit/auto-animate": "^0.9.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@types/dompurify": "3.0.5",
    "@uiw/react-codemirror": "4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "docx": "9.6.1",
    "dompurify": "3.4.3",
    "katex": "0.16.47",
    "lucide-react": "1.16.0",
    "mammoth": "1.12.0",
    "mermaid": "^11.15.0",
    "motion": "^12.42.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vditor": "3.11.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@tauri-apps/cli": "2.11.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "29.1.1",
    "jszip": "3.10.1",
    "playwright": "1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "4.1.6"
  }
}
