{
  "name": "typola",
  "private": true,
  "version": "0.1.0",
  "description": "A desktop Markdown editor inspired by Typora.",
  "author": "Typola contributors",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "electron:compile": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --outdir=electron --external:electron --external:fs --external:path --external:node-pty",
    "electron:dev": "npm run electron:compile && concurrently -k \"vite\" \"npm run electron:start\"",
    "electron:start": "wait-on http://localhost:1420 && electron .",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron": "electron"
  },
  "dependencies": {
    "@milkdown/components": "^7.20.0",
    "@milkdown/core": "^7.6.0",
    "@milkdown/plugin-history": "^7.6.0",
    "@milkdown/plugin-listener": "^7.6.0",
    "@milkdown/plugin-slash": "^7.6.0",
    "@milkdown/plugin-tooltip": "^7.6.0",
    "@milkdown/preset-commonmark": "^7.6.0",
    "@milkdown/preset-gfm": "^7.6.0",
    "@milkdown/react": "^7.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-log": "^5.2.0",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.14.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "shiki": "^1.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-icon-builder": "^2.0.1",
    "esbuild": "^0.24.0",
    "jsdom": "^26.1.0",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.typola.app",
    "productName": "Typola",
    "copyright": "Copyright © 2026 Typola",
    "compression": "normal",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/node-pty/prebuilds/win32-x64/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!**/*.pdb",
      "!**/node_modules/node-pty/src{,/**/*}",
      "!**/node_modules/node-pty/scripts{,/**/*}",
      "!**/node_modules/node-pty/deps{,/**/*}",
      "!**/node_modules/node-pty/third_party{,/**/*}",
      "!**/node_modules/node-pty/prebuilds/darwin-arm64{,/**/*}",
      "!**/node_modules/node-pty/prebuilds/darwin-x64{,/**/*}",
      "!**/node_modules/node-pty/prebuilds/win32-arm64{,/**/*}",
      "!**/node_modules/node-pty/lib/**/*.test.*",
      "!**/node_modules/node-pty/node_modules/node-addon-api{,/**/*}",
      "!**/node_modules/node-pty/*.md",
      "!**/node_modules/node-pty/*.txt",
      "!**/node_modules/node-pty/vcbuild.bat"
    ],
    "extraResources": [
      {
        "from": "resources/typola.ico",
        "to": "typola.ico"
      }
    ],
    "afterPack": "scripts/patchWindowsExecutable.cjs",
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/typola.ico",
      "sign": false,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Typola-portable-${version}.exe"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttttstc/Typola.git"
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ttttstc/Typola/issues"
  },
  "homepage": "https://github.com/ttttstc/Typola#readme"
}
